{
  "name": "ecommerce-multi-vendor-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "web-app",
    "mobile-app",
    "admin-dashboard",
    "seller-dashboard",
    "delivery-app"
  ],
  "scripts": {
    "dev": "concurrently -n BACKEND,WEB -c blue,green \"npm:dev:backend\" \"npm:dev:web\"",
    "dev:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-backend.ps1",
    "dev:web": "npm run dev --prefix web-app",
    "dev:mobile": "npm run start --prefix mobile-app",
    "lint": "echo \"Run lint per package\"",
    "test": "echo \"Run tests per package\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "dotenv": "^16.4.5"
  }
}
