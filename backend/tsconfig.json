{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",

    "incremental": true,
    "skipLibCheck": true,


    "strict": true,
    "noImplicitAny": false
  },
  "exclude": ["node_modules", "dist", "db-schemas", "db-seeds"]
}


